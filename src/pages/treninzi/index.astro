---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import PageHero from "../../components/PageHero.astro";
import PricingBands from "../../components/PricingBands.astro";
import ProgramRows from "../../components/ProgramRows.astro";
import { business, ctaLinks, primaryPhone } from "../../data/business";
import { programs, pilatesSchedule } from "../../data/programs";
import { pricingLookup } from "../../data/pricing";
import { seoByPath } from "../../data/seo";
import { formatRsd, formatSupplement } from "../../utils/format-currency";

const seo = seoByPath["/treninzi/"];
const breadcrumbs = [
  { name: "Početna", path: "/" },
  { name: "Treninzi", path: "/treninzi/" },
];
const dailyPackage = pricingLookup["daily-package"];
const monthlyPackage = pricingLookup["monthly-package"];
const guidedSupplement = pricingLookup["monthly-guided-supplement"];
const personalDailySupplement = pricingLookup["daily-personal-supplement"];
const personal8Supplement = pricingLookup["monthly-personal-8-supplement"];
const personal12Supplement = pricingLookup["monthly-personal-12-supplement"];
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  pathname="/treninzi/"
  breadcrumbs={breadcrumbs}
>
  <PageHero
    eyebrow="02 / Treninzi"
    title="Izaberi način treninga."
    lead="Samostalni, vođeni, personalni i pilates termini predstavljeni su samo kroz potvrđene informacije i postojeći cenovnik."
    mark="02"
    infoRows={[
      { label: "Lokacija", value: business.address.street },
      { label: "Pilates", value: `${pilatesSchedule.shortDays}, ${pilatesSchedule.time}` },
      { label: "Poziv", value: primaryPhone.display },
    ]}
    actions={[
      { label: "Pozovi i proveri termin", href: ctaLinks.call },
      { label: "Pogledaj cenovnik", href: "/cenovnik/", variant: "secondary" },
    ]}
  >
    <Fragment slot="breadcrumbs">
      <Breadcrumbs items={breadcrumbs} />
    </Fragment>
  </PageHero>

  <section class="section section--surface section--tight">
    <div class="section__inner">
      <div class="section-copy">
        <span class="rule-label">Programski indeks</span>
        <h2 class="section-title">Sidreni pregled četiri programa.</h2>
      </div>
      <ProgramRows items={programs} linkMode="internal" />
    </div>
  </section>

  <section class="section section--paper">
    <div class="section__inner details">
      <article id="samostalni" class="detail-card surface-frame">
        <div class="detail-card__top">
          <span class="detail-card__index">01</span>
          <div>
            <h2>Samostalni trening</h2>
            <p>
              Za trening svojim ritmom u prostoru Fit Plus Gym-a, uz izbor paketa iz
              dostavljenog cenovnika.
            </p>
          </div>
        </div>
        <ul role="list">
          <li>Dnevni paket: <strong class="tabular">{formatRsd(Number(dailyPackage.amount))}</strong></li>
          <li>Mesečni paket: <strong class="tabular">{formatRsd(Number(monthlyPackage.amount))}</strong></li>
          <li>Paket za 3 meseca dostupan je kroz poseban cenovni red.</li>
        </ul>
        <a class="text-link" href="/cenovnik/">Pogledaj cene paketa</a>
      </article>

      <article id="vodjeni" class="detail-card surface-frame">
        <div class="detail-card__top">
          <span class="detail-card__index">02</span>
          <div>
            <h2>Vođeni trening</h2>
            <p>
              Trening uz vođenje trenera prikazan je kroz potvrđenu varijantu od 12
              termina, bez izmišljanja dodatnih uslova.
            </p>
          </div>
        </div>
        <ul role="list">
          <li>12 termina prema dostavljenom cenovniku.</li>
          <li>Doplata uz mesečni paket: <strong class="tabular">{formatSupplement(Number(guidedSupplement.amount))}</strong></li>
          <li>Detalje termina proveri direktnim pozivom teretani.</li>
        </ul>
        <a class="text-link" href={ctaLinks.call}>Pozovi i proveri detalje</a>
      </article>

      <article id="personalni" class="detail-card surface-frame">
        <div class="detail-card__top">
          <span class="detail-card__index">03</span>
          <div>
            <h2>Personalni trening</h2>
            <p>
              Personalni rad je prikazan isključivo kroz potvrđene stavke iz cenovnika,
              uz zadržan znak + dok se ne potvrdi način obračuna.
            </p>
          </div>
        </div>
        <ul role="list">
          <li>
            Uz dnevni paket: <strong class="tabular">{formatSupplement(Number(personalDailySupplement.amount))}</strong>
          </li>
          <li>
            8 termina uz mesečni paket: <strong class="tabular">{formatSupplement(Number(personal8Supplement.amount))}</strong>
          </li>
          <li>
            12 termina uz mesečni paket: <strong class="tabular">{formatSupplement(Number(personal12Supplement.amount))}</strong>
          </li>
        </ul>
        <a class="text-link" href={ctaLinks.call}>Pozovi teretanu</a>
      </article>

      <article id="pilates" class="detail-card surface-frame">
        <div class="detail-card__top">
          <span class="detail-card__index">04</span>
          <div>
            <h2>Pilates</h2>
            <p>
              Pilates je trenutno prikazan samo kroz potvrđene termine, bez cene,
              instruktora ili dodatnih detalja koji nisu dostavljeni.
            </p>
          </div>
        </div>
        <ul role="list">
          <li>{pilatesSchedule.days.join(", ")}</li>
          <li class="tabular">{pilatesSchedule.time}</li>
          <li>{pilatesSchedule.note}</li>
        </ul>
        <a class="text-link" href={ctaLinks.call}>Pozovi i proveri termin</a>
      </article>
    </div>
  </section>

  <section class="section section--charcoal">
    <div class="section__inner">
      <div class="section-copy section-copy--light">
        <span class="rule-label">Povezan cenovnik</span>
        <h2 class="section-title">Programi ostaju vezani za iste cene.</h2>
      </div>
      <PricingBands mode="teaser" />
    </div>
  </section>

  <section class="section section--surface">
    <div class="section__inner trainings-contact">
      <div class="trainings-contact__copy">
        <span class="rule-label">Završni kontakt</span>
        <h2 class="section-title">Telefon, cenovnik i lokacija ostaju glavni CTA.</h2>
        <p class="lead">
          Ako želiš vođeni, personalni ili pilates trening, pozovi i proveri detalje
          termina pre dolaska.
        </p>
      </div>
      <div class="trainings-contact__actions">
        <a class="button button--primary" href={ctaLinks.call}>Pozovi {primaryPhone.display}</a>
        <a class="button button--secondary" href="/lokacija/">Idi na lokaciju</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .section-copy {
    display: grid;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .section-copy--light .lead {
    color: rgba(250, 249, 246, 0.82);
  }

  .details {
    display: grid;
    gap: var(--space-4);
  }

  .detail-card {
    padding: var(--space-5);
    display: grid;
    gap: var(--space-4);
    background: var(--color-surface);
    scroll-margin-top: calc(var(--header-height) + var(--space-4));
  }

  .detail-card__top {
    display: grid;
    grid-template-columns: minmax(3rem, 4rem) 1fr;
    gap: var(--space-4);
    align-items: start;
  }

  .detail-card__index {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4vw, 3.3rem);
    font-weight: 800;
    line-height: 0.92;
    color: var(--color-signal);
  }

  .detail-card h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw, 2.8rem);
    font-weight: 700;
    line-height: 0.94;
    text-transform: uppercase;
    margin-bottom: var(--space-2);
  }

  .detail-card ul {
    display: grid;
    gap: var(--space-2);
    padding-left: 1.2rem;
  }

  .trainings-contact {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(18rem, 0.85fr);
    gap: var(--grid-gap);
    align-items: start;
  }

  .trainings-contact__copy {
    display: grid;
    gap: var(--space-4);
  }

  .trainings-contact__actions {
    display: grid;
    gap: var(--space-3);
  }

  @media (max-width: 47.9375rem) {
    .detail-card {
      padding: var(--space-4);
    }

    .detail-card__top {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }

    .trainings-contact {
      grid-template-columns: 1fr;
    }
  }
</style>
