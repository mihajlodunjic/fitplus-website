---
import { business, ctaLinks, localSummary, primaryPhone, secondaryPhone } from "../data/business";
import { desktopNavigation, mobileNavigation } from "../data/navigation";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

function isActive(pathname: string, href: string) {
  return pathname === href;
}
---

<header class="site-header">
  <div class="site-header__inner section__inner">
    <a class="site-brand" href="/">
      <span class="site-brand__logo">
        <img
          src={business.logo.src}
          width={business.logo.width}
          height={business.logo.height}
          alt=""
          loading="eager"
          decoding="async"
        />
      </span>
      <span class="site-brand__text">
        <span class="site-brand__name">Fit Plus Gym</span>
        <span class="site-brand__place">Jajinci</span>
      </span>
    </a>

    <nav class="site-header__nav" aria-label="Glavna navigacija">
      <ul role="list">
        {
          desktopNavigation.map((item) => {
            const active = isActive(currentPath, item.href);

            return (
              <li>
                <a href={item.href} aria-current={active ? "page" : undefined} data-active={active}>
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>

    <div class="site-header__actions">
      <a class="site-header__phone nowrap tabular" href={primaryPhone.href}>
        {primaryPhone.display}
      </a>

      <button
        class="menu-toggle"
        type="button"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Otvori navigaciju"
        data-menu-button
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="mobile-menu" hidden data-mobile-menu data-state="closed">
    <div class="mobile-menu__panel" data-menu-panel>
      <nav aria-label="Mobilna navigacija">
        <ul role="list" class="mobile-menu__nav">
          {
            mobileNavigation.map((item) => (
              <li>
                <a href={item.href} data-menu-link>
                  <span class="mobile-menu__index">{item.menuIndex}</span>
                  <span class="mobile-menu__label">{item.label}</span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="mobile-menu__meta surface-frame">
        <p class="mobile-menu__today" data-today-summary>
          {localSummary.todayFallback}
        </p>
        <p class="mobile-menu__address">{localSummary.address}</p>
        <div class="mobile-menu__links">
          <a class="nowrap tabular" href={primaryPhone.href} data-menu-link>
            {primaryPhone.display}
          </a>
          <a class="nowrap tabular" href={secondaryPhone.href} data-menu-link>
            {secondaryPhone.display}
          </a>
          <a href={ctaLinks.instagram} data-menu-link rel="noreferrer" target="_blank">
            {business.instagram.handle}
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-ink);
    color: var(--color-surface);
    border-bottom: var(--border-base) solid var(--color-line-dark);
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-5);
    align-items: center;
    min-height: var(--header-height);
  }

  .site-brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
  }

  .site-brand__logo {
    width: clamp(3rem, 4.4vw, 4.25rem);
    aspect-ratio: 1;
    flex: 0 0 auto;
    border-radius: 999px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.04);
    padding: 0.18rem;
  }

  .site-brand__logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .site-brand__text {
    display: grid;
    gap: 0.08rem;
  }

  .site-brand__name {
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 2.1vw, 2rem);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .site-brand__place {
    font-size: var(--font-size-label);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(250, 249, 246, 0.76);
  }

  .site-header__nav ul {
    display: flex;
    justify-content: center;
    gap: clamp(var(--space-4), 2vw, var(--space-6));
    flex-wrap: wrap;
  }

  .site-header__nav a {
    display: inline-flex;
    min-height: var(--touch-target);
    align-items: center;
    font-weight: 700;
    text-decoration: none;
    position: relative;
  }

  .site-header__nav a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.4rem;
    height: 0.15rem;
    background: var(--color-signal);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition-base);
  }

  .site-header__nav a:hover::after,
  .site-header__nav a:focus-visible::after,
  .site-header__nav a[data-active="true"]::after {
    transform: scaleX(1);
  }

  .site-header__actions {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--space-3);
  }

  .site-header__phone {
    min-height: var(--touch-target);
    display: inline-flex;
    align-items: center;
    font-weight: 700;
    text-decoration: none;
  }

  .menu-toggle {
    display: none;
    position: relative;
    width: 3rem;
    height: 3rem;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 0.34rem;
    padding: 0;
    cursor: pointer;
  }

  .menu-toggle span {
    display: block;
    width: 1.5rem;
    height: 0.12rem;
    background: currentColor;
    transition:
      transform var(--transition-base),
      opacity var(--transition-base);
  }

  .menu-toggle[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(0.46rem) rotate(45deg);
  }

  .menu-toggle[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-0.46rem) rotate(-45deg);
  }

  .mobile-menu {
    position: fixed;
    inset: var(--header-height) 0 0;
    background: rgba(17, 24, 32, 0.72);
    padding: 0 var(--page-margin) var(--page-margin);
    opacity: 0;
    transition: opacity var(--transition-slow);
  }

  .mobile-menu[data-state="open"] {
    opacity: 1;
  }

  .mobile-menu__panel {
    margin-left: auto;
    width: min(100%, 24rem);
    height: 100%;
    background: var(--color-ink);
    border-inline: var(--border-base) solid var(--color-line-dark);
    border-bottom: var(--border-base) solid var(--color-line-dark);
    padding: var(--space-5);
    display: grid;
    gap: var(--space-6);
    align-content: space-between;
    transform: translateX(1.25rem);
    transition: transform var(--transition-slow);
    overflow-y: auto;
  }

  .mobile-menu[data-state="open"] .mobile-menu__panel {
    transform: translateX(0);
  }

  .mobile-menu__nav {
    display: grid;
    gap: var(--space-2);
  }

  .mobile-menu__nav a {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-3);
    align-items: baseline;
    min-height: 3.3rem;
    padding-block: var(--space-2);
    border-bottom: var(--border-base) solid var(--color-line-dark);
    text-decoration: none;
  }

  .mobile-menu__index {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-signal);
  }

  .mobile-menu__label {
    font-family: var(--font-display);
    font-size: clamp(2rem, 7vw, 3rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .mobile-menu__meta {
    padding: var(--space-4);
    display: grid;
    gap: var(--space-3);
    background: var(--color-surface);
    color: var(--color-text);
  }

  .mobile-menu__today {
    font-size: var(--font-size-label);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-signal);
  }

  .mobile-menu__address {
    font-weight: 600;
  }

  .mobile-menu__links {
    display: grid;
    gap: var(--space-2);
  }

  .mobile-menu__links a {
    width: fit-content;
    font-weight: 700;
  }

  @media (max-width: 70rem) {
    .site-header__phone {
      display: none;
    }
  }

  @media (max-width: 47.9375rem) {
    .site-header__inner {
      grid-template-columns: auto 1fr auto;
      gap: var(--space-3);
    }

    .site-header__nav {
      display: none;
    }

    .site-brand__logo {
      width: clamp(3rem, 12vw, 3.5rem);
    }

    .site-brand__text {
      gap: 0;
    }

    .site-brand__name {
      font-size: 1.45rem;
    }

    .site-brand__place {
      font-size: 0.72rem;
    }

    .menu-toggle {
      display: inline-flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .menu-toggle span,
    .mobile-menu,
    .mobile-menu__panel,
    .site-header__nav a::after {
      transition: none;
    }
  }
</style>
