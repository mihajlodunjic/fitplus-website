---
import { business, ctaLinks } from "../data/business";
import { openingHoursSummary } from "../data/opening-hours";
import { pricingPackages } from "../data/pricing";
import { programs } from "../data/programs";
import { formatRsd } from "../utils/format-currency";

const monthlyPackage = pricingPackages.find((item) => item.id === "monthly-package");
const trainingModes = programs.map((program) => program.name).join(" / ");
---

<section class="home-hero section section--ink">
  <div class="section__inner grid-shell home-hero__grid">
    <div class="home-hero__content">
      <p class="meta-axis">
        <span>Jajinci</span>
        <span>Voždovac</span>
        <span>{business.address.prominentNumber}</span>
      </p>

      <h1 class="display-title">Teretana u Jajincima. Prostor za tvoj trening.</h1>

      <p class="lead">
        Samostalni, vođeni i personalni treninzi, uz termine pilatesa. Fit Plus Gym se
        nalazi u Stojana Ljubića 71b.
      </p>

      <div class="button-row">
        <a class="button button--primary" href={ctaLinks.pricing}>
          Pogledaj cenovnik
        </a>
        <a class="text-link nowrap" href={ctaLinks.call}>
          Pozovi teretanu
        </a>
      </div>

      <div class="home-hero__modes ink-frame">
        <span class="rule-label">Načini treninga</span>
        <p>{trainingModes}</p>
      </div>
    </div>

    <aside class="home-hero__aside surface-frame">
      <div class="home-hero__stamp">
        <img
          src={business.logo.src}
          width={business.logo.width}
          height={business.logo.height}
          alt=""
          loading="eager"
          decoding="async"
        />
      </div>

      <dl class="home-hero__facts">
        <div>
          <dt>Adresa</dt>
          <dd>{business.address.street}</dd>
        </div>
        <div>
          <dt>Radno vreme</dt>
          <dd>{openingHoursSummary.combined}</dd>
        </div>
        {monthlyPackage && (
          <div>
            <dt>Mesečni paket</dt>
            <dd class="tabular">{formatRsd(monthlyPackage.amount)}</dd>
          </div>
        )}
      </dl>
    </aside>
  </div>

  <div class="home-hero__signal">
    <div class="section__inner">
      <p>{business.address.areaLine}</p>
    </div>
  </div>
</section>

<style>
  .home-hero {
    padding-bottom: 0;
  }

  .home-hero__grid {
    align-items: start;
    padding-bottom: var(--section-space-tight);
  }

  .home-hero__content {
    grid-column: span 8;
    display: grid;
    gap: var(--space-4);
  }

  .home-hero__content .lead {
    color: rgba(250, 249, 246, 0.84);
  }

  .home-hero__aside {
    grid-column: span 4;
    padding: var(--space-5);
    display: grid;
    gap: var(--space-5);
    align-content: start;
    background: var(--color-surface);
  }

  .home-hero__stamp {
    width: clamp(3.5rem, 10vw, 4.8rem);
    aspect-ratio: 1;
    border-radius: 999px;
    overflow: hidden;
    padding: 0.18rem;
    background: var(--color-ink);
  }

  .home-hero__stamp img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .home-hero__facts {
    display: grid;
    gap: var(--space-3);
  }

  .home-hero__facts div {
    display: grid;
    gap: 0.2rem;
    padding-top: var(--space-3);
    border-top: var(--border-base) solid var(--color-line);
  }

  .home-hero__facts dt {
    font-size: var(--font-size-label);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
  }

  .home-hero__facts dd {
    font-weight: 700;
  }

  .home-hero__modes {
    display: grid;
    gap: var(--space-3);
    padding: var(--space-4);
    max-width: 36rem;
  }

  .home-hero__modes p {
    font-weight: 700;
  }

  .home-hero__signal {
    background: var(--color-signal);
    color: var(--color-surface);
    border-top: var(--border-base) solid rgba(255, 255, 255, 0.18);
    border-bottom: var(--border-base) solid rgba(255, 255, 255, 0.18);
    padding-block: var(--space-3);
  }

  .home-hero__signal p {
    font-size: var(--font-size-label);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  @media (max-width: 63.9375rem) {
    .home-hero__content,
    .home-hero__aside {
      grid-column: span 4;
    }
  }

  @media (max-width: 47.9375rem) {
    .home-hero__content,
    .home-hero__aside {
      grid-column: 1 / -1;
    }

    .home-hero__content {
      gap: var(--space-4);
    }

    .home-hero__aside {
      gap: var(--space-4);
    }

    .home-hero__modes {
      max-width: none;
    }
  }
</style>
